# AWS
AWS_REGION=ap-south-1

# Gemini (Google AI Studio)
GEMINI_API_KEY=<your-google-ai-studio-api-key>
GEMINI_MODEL_ID=gemini-2.5-flash

# SES
SES_SENDER_EMAIL=<your-verified-ses-email>
SES_RECIPIENT_EMAIL=<your-email>

# DynamoDB
DYNAMO_TABLE_NAME=self-healing-incidents

# API Gateway (populated by Terraform output after apply)
API_GATEWAY_BASE_URL=<populated-by-terraform>

# Token Security
APPROVAL_TOKEN_SECRET=<random-32-char-string>
APPROVAL_TOKEN_EXPIRY_MINUTES=15

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=dev
